        "# High SA -> pH 6.13 (More alkaline)\n",
        "# Low SA -> pH 5.13 (More acidic)\n",
        "\n",
        "def apply_environmental_context(model, condition_type):\n",
        "    \"\"\"\n",
        "    Adjusts the proton (H+) efflux potential based on skin pH.\n",
        "    NMR data handles the chemical availability; this handles the physical gradient.\n",
        "    \"\"\"\n",
        "    m = model.copy()\n",
        "\n",
        "    # Proton exchange reaction ID in Human-GEM\n",
        "    h_plus_exchange = \"MAR09048\"\n",
        "\n",
        "    if condition_type == 'high':\n",
        "        # pH 6.13: Lower external H+ concentration.\n",
        "        # It is easier for the cell to dump waste protons.\n",
        "        m.reactions.get_by_id(h_plus_exchange).lower_bound = -1000.0\n",
        "\n",
        "    elif condition_type == 'low':\n",
        "        # pH 5.13: Higher external H+ concentration (Acidic).\n",
        "        # Resistance (back-pressure) makes it harder to export protons.\n",
        "        m.reactions.get_by_id(h_plus_exchange).lower_bound = -400.0\n",
        "\n",
        "    return m\n",
        "\n",
        "# Apply to current models\n",
        "model_high_final = apply_environmental_context(model_high_KER1, 'high')\n",
        "model_low_final = apply_environmental_context(model_low_KER1, 'low')\n",
        "\n"
