        "# Now plotting up and downregulated pathways instead of absolute flux\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# PREPARE DATA\n",
        "subsys_compare = fva_export.groupby('subsystem')[['high_pfba', 'low_pfba']].apply(lambda x: x.abs().mean())\n",
        "\n",
        "# Calculate the \"Relative Shift\" (Mean-Centered)\n",
        "row_means = subsys_compare.mean(axis=1)\n",
        "plot_df = subsys_compare.sub(row_means, axis=0)\n",
        "\n",
        "# Filter for the top 40 most dynamic subsystems\n",
        "plot_df['total_move'] = plot_df.abs().sum(axis=1)\n",
        "plot_df = plot_df.sort_values('total_move', ascending=False).head(40).drop(columns='total_move')\n",
        "plot_df.columns = ['High S. aureus', 'Low S. aureus']\n",
        "\n",
        "\n",
        "\n",
        "#  CALCULATE FVA SIGNIFICANCE\n",
        "def get_sig_star(row):\n",
        "    # Calculate relative difference\n",
        "    # Use a small epsilon (0.1) to avoid division by zero\n",
        "    high = abs(row['high_pfba'])\n",
        "    low = abs(row['low_pfba'])\n",
        "   # Check if the raw shift is > 1.0 (to avoid stars on near-zero noise)\n",
        "    if (max(high, low) > 1.5 * min(high, low)) and (abs(high - low) > 1.0):\n",
        "        return \"*\"\n",
        "    return \"\"\n",
        "\n",
        "fva_export['robust_sig'] = fva_export.apply(get_sig_star, axis=1)\n",
        "# Group stars by subsystem\n",
        "subsys_sig = fva_export.groupby('subsystem')['robust_sig'].apply(lambda x: \"*\" if \"*\" in x.values else \"\")\n",
        "\n",
        "\n",
        "# Get the name from BIO_NAMES\n",
        "# Then add the star if it exists\n",
        "new_y_labels = [\n",
        "    f\"{BIO_NAMES.get(label, label)} {subsys_sig.get(label, '')}\"\n",
        "    for label in plot_df.index\n",
        "]\n",
        "\n",
        "# PLOT\n",
        "plt.figure(figsize=(14, 18))\n",
        "\n",
        "ax = sns.heatmap(plot_df,\n",
        "                 annot=subsys_compare.loc[plot_df.index].values,\n",
        "                 fmt=\".1f\",\n",
        "                 cmap=\"RdBu_r\",\n",
        "                 center=0,\n",
        "                 annot_kws={\"size\": 14},\n",
        "                 cbar_kws={'label': 'Mean-Centered Flux Shift'})\n",
