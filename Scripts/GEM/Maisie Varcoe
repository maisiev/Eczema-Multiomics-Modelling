        "        for reaction in met.reactions:\n",
        "            # Check for standard 'EX_' OR your specific 'MAR' pattern\n",
        "            # Based on your output, 'MAR' is the key identifier\n",
        "            if reaction.id.startswith('EX_') or reaction.id.startswith('MAR'):\n",
        "                return reaction.id\n",
