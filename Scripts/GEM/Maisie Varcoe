        "def get_exchange_id(model, mam_id):\n",
        "    \"\"\"Finds the exchange reaction for a specific metabolite MAM ID.\"\"\"\n",
        "    try:\n",
        "        met = model.metabolites.get_by_id(mam_id)\n",
        "        # Exchange reactions typically involve only the metabolite and the boundary\n",
        "        for reaction in met.reactions:\n",
        "            # Check if it's an exchange (usually labeled with 'EX_')\n",
        "            if reaction.id.startswith('EX_'):\n",
        "                return reaction.id\n",
        "    except KeyError:\n",
        "        return None\n",
        "    return None\n",
        "\n",
