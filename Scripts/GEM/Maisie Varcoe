      "source": [
        "\"\"\"\n",
        "GEM_pathway_table_builder.py\n",
        "============================\n",
        "Loads JSON model to extract metabolites and genes.\n",
        "\n",
        "Outputs:\n",
        "  {project_folder}KER1_Pathway_Metabolite_Gene_Table.xlsx   (two sheets)\n",
        "  {project_folder}KER1_Pathway_Metabolite_Gene_Table.csv\n",
        "\"\"\"\n",
        "\n",
        "import re\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import cobra\n",
        "from openpyxl import load_workbook\n",
        "from openpyxl.styles import PatternFill, Font, Alignment, Border, Side\n",
        "\n",
        "# ── CONFIG ────────────────────────────────────────────────────────────────────\n",
        "FLUX_THRESHOLD   = 1e-6   # reactions below this in BOTH conditions are skipped\n",
        "ACTIVE_ONLY      = True   # set False to include all reactions in fva_export\n",
        "TOP_N_PATHWAYS   = None   # None = all; set e.g. 20 to restrict to top pathways\n",
        "MAX_METS_SHOWN   = 8      # truncate very long metabolite lists in cells\n",
        "EXCLUDE_NO_GPR   = False  # set True to drop reactions with no gene association\n",
        "EXCLUDE_PATHWAYS = {      # pathway names (after BIO_NAMES mapping) to drop entirely\n",
        "    \"Artificial reactions\",\n",
        "}\n",
        "# ─────────────────────────────────────────────────────────────────────────────\n",
        "\n",
        "\n",
        "# ── STEP 1: Load the saved model ──────────────────────────────────────────────\n",
        "model_path = f\"{project_folder}KER1_Model_Updated6.json\"\n",
        "print(f\"Loading model from: {model_path}\")\n",
        "_gem = cobra.io.load_json_model(model_path)\n",
        "print(f\"  Reactions: {len(_gem.reactions)} | Metabolites: {len(_gem.metabolites)} | Genes: {len(_gem.genes)}\")\n",
        "\n",
        "\n",
        "# ── STEP 2: Helper functions ──────────────────────────────────────────────────\n",
        "\n",
        "def _extract_genes(gpr_string):\n",
        "    \"\"\"Sorted, deduplicated Ensembl IDs from a GPR rule string.\"\"\"\n",
        "    if not gpr_string or not gpr_string.strip():\n",
        "        return []\n",
        "    return sorted(set(re.findall(r\"ENSG\\d+\", gpr_string)))\n",
        "\n",
        "\n",
        "def _fmt_list(items, max_n=MAX_METS_SHOWN):\n",
        "    if not items:\n",
        "        return \"\"\n",
        "    if len(items) > max_n:\n",
        "        return \"; \".join(items[:max_n]) + f\" … (+{len(items) - max_n} more)\"\n",
        "    return \"; \".join(items)\n",
        "\n",
        "\n",
        "def _fva_range(mn, mx):\n",
        "    try:\n",
        "        return f\"{float(mn):.2f} – {float(mx):.2f}\"\n",
        "    except (TypeError, ValueError):\n",
        "        return \"\"\n",
        "\n",
        "\n",
        "def _resolve_name(rid, rxn):\n",
        "    \"\"\"\n",
        "    Return the best available human-readable name for a reaction.\n",
        "    Priority: human_readable_labels (by ID) > REACTION_NAMES (by name) > rxn.name > rid\n",
        "    Falls back to rid only if the raw name is blank or identical to the ID.\n",
        "    \"\"\"\n",
        "    if rid in human_readable_labels:\n",
        "        return human_readable_labels[rid]\n",
        "    raw = rxn.name or \"\"\n",
        "    resolved = REACTION_NAMES.get(raw, raw)\n",
        "    # If still looks like a raw MAR ID or is blank, return the ID so it's obvious\n",
        "    if not resolved or re.fullmatch(r\"MAR\\d+\", resolved):\n",
        "        return f\"{rid} (unnamed)\"\n",
        "    return resolved\n",
        "\n",
        "\n",
        "# ── STEP 3: Build one row per reaction ───────────────────────────────────────\n",
        "print(\"Building pathway → metabolite → gene rows…\")\n",
        "records = []\n",
        "\n",
        "for rid, row in fva_export.iterrows():\n",
        "\n",
        "    high_flux = float(row.get(\"high_pfba\", 0) or 0)\n",
        "    low_flux  = float(row.get(\"low_pfba\",  0) or 0)\n",
        "    abs_diff  = float(row.get(\"abs_diff\",  abs(high_flux - low_flux)))\n",
        "\n",
        "    if ACTIVE_ONLY and abs(high_flux) < FLUX_THRESHOLD and abs(low_flux) < FLUX_THRESHOLD:\n",
        "        continue\n",
        "\n",
        "    try:\n",
        "        rxn = _gem.reactions.get_by_id(rid)\n",
        "    except KeyError:\n",
        "        continue\n",
        "\n",
        "    # ── Pathway label ──────────────────────────────────────────────────────\n",
        "    raw_subsys = rxn.subsystem or row.get(\"pathway\", \"Unknown\")\n",
        "    pathway    = BIO_NAMES.get(raw_subsys, raw_subsys)\n",
        "\n",
        "    # ── Drop excluded pathways ─────────────────────────────────────────────\n",
        "    if pathway in EXCLUDE_PATHWAYS:\n",
        "        continue\n",
        "\n",
        "    # ── Genes ──────────────────────────────────────────────────────────────\n",
        "    genes = _extract_genes(rxn.gene_reaction_rule)\n",
        "\n",
        "    # ── Drop no-GPR reactions if configured ───────────────────────────────\n",
        "    if EXCLUDE_NO_GPR and not genes:\n",
        "        continue\n",
        "\n",
        "    # ── Reaction display name ──────────────────────────────────────────────\n",
        "    rxn_name = _resolve_name(rid, rxn)\n",
        "\n",
        "    # ── Metabolites ────────────────────────────────────────────────────────\n",
        "    substrates = [m.name or m.id for m, c in rxn.metabolites.items() if c < 0]\n",
        "    products   = [m.name or m.id for m, c in rxn.metabolites.items() if c > 0]\n",
        "\n",
        "    # ── FVA ranges ────────────────────────────────────────────────────────\n",
        "    high_fva = _fva_range(row.get(\"high_min\"), row.get(\"high_max\"))\n",
        "    low_fva  = _fva_range(row.get(\"low_min\"),  row.get(\"low_max\"))\n",
        "\n",
        "    # ── Significance flag ──────────────────────────────────────────────────\n",
        "    mag = max(abs(high_flux), abs(low_flux))\n",
        "    mn  = min(abs(high_flux), abs(low_flux))\n",
        "    sig = \"✓\" if abs_diff > 1.0 and mag > 1.5 * mn + 1e-9 else \"\"\n",
        "\n",
        "    records.append({\n",
        "        \"Pathway\":    pathway,\n",
        "        \"_raw_subsys\":            raw_subsys,\n",
        "        \"Reaction ID\":            rid,\n",
        "        \"Reaction Name\":          rxn_name,\n",
        "        \"Substrates\":             _fmt_list(substrates),\n",
        "        \"Products\":               _fmt_list(products),\n",
        "        \"All Metabolites\":        _fmt_list(substrates + products),\n",
        "        \"Genes (Ensembl)\":        \"; \".join(genes) if genes else \"No GPR\",\n",
        "        \"Gene Count\":             len(genes),\n",
        "        \"High SA pFBA Flux\":      round(high_flux, 4),\n",
        "        \"Low SA pFBA Flux\":       round(low_flux,  4),\n",
        "        \"Absolute Flux Shift\":    round(abs_diff,  4),\n",
        "        \"High SA FVA Range\":      high_fva,\n",
        "        \"Low SA FVA Range\":       low_fva,\n",
        "        \"Significant (*)\":        sig,\n",
        "    })\n",
        "\n",
        "df_table = (pd.DataFrame(records)\n",
        "              .sort_values([\"Pathway\", \"Absolute Flux Shift\"],\n",
        "                           ascending=[True, False])\n",
        "              .reset_index(drop=True))\n",
        "\n",
        "df_export = df_table.drop(columns=[\"_raw_subsys\"])\n",
        "\n",
        "if TOP_N_PATHWAYS:\n",
        "    top_pw = (df_export.groupby(\"Pathway\")[\"Absolute Flux Shift\"]\n",
        "              .sum().sort_values(ascending=False).head(TOP_N_PATHWAYS).index)\n",
        "    df_export = df_export[df_export[\"Pathway\"].isin(top_pw)]\n",
        "\n",
        "n_unnamed = df_export[\"Reaction Name\"].str.endswith(\"(unnamed)\").sum()\n",
        "print(f\"  → {len(df_export)} reactions | {df_export['Pathway'].nunique()} pathways\")\n",
        "print(f\"  → {n_unnamed} reactions with no name in dictionaries (flagged as 'unnamed')\")\n",
        "if EXCLUDE_NO_GPR:\n",
        "    print(f\"  → No-GPR reactions excluded\")\n",
        "print(f\"  → Excluded pathways: {EXCLUDE_PATHWAYS}\")\n",
        "\n",
        "\n",
        "# ── STEP 4: Pathway summary ───────────────────────────────────────────────────\n",
        "def _unique_genes(series):\n",
        "    combined = \"; \".join(g for g in series if g and g != \"No GPR\")\n",
        "    return len(set(re.findall(r\"ENSG\\d+\", combined)))\n",
        "\n",
        "df_summary = (df_export.groupby(\"Pathway\")\n",
        "              .agg(\n",
        "                  Reactions         = (\"Reaction ID\",         \"count\"),\n",
        "                  Unique_Genes      = (\"Genes (Ensembl)\",     _unique_genes),\n",
        "                  Total_Flux_Shift  = (\"Absolute Flux Shift\", \"sum\"),\n",
        "                  Mean_High_Flux    = (\"High SA pFBA Flux\",   lambda x: round(x.abs().mean(), 4)),\n",
        "                  Mean_Low_Flux     = (\"Low SA pFBA Flux\",    lambda x: round(x.abs().mean(), 4)),\n",
        "                  Significant_Rxns  = (\"Significant (*)\",     lambda x: (x == \"✓\").sum()),\n",
        "              )\n",
        "              .sort_values(\"Total_Flux_Shift\", ascending=False)\n",
        "              .reset_index())\n",
        "\n",
        "\n",
        "# ── STEP 5: Write to Excel ────────────────────────────────────────────────────\n",
        "xlsx_path = f\"{project_folder}KER1_Pathway_Metabolite_Gene_Table6.xlsx\"\n",
        "csv_path  = f\"{project_folder}KER1_Pathway_Metabolite_Gene_Table6.csv\"\n",
        "\n",
        "with pd.ExcelWriter(xlsx_path, engine=\"openpyxl\") as writer:\n",
        "    df_export.to_excel(writer,  index=False, sheet_name=\"Pathway Table\")\n",
        "    df_summary.to_excel(writer, index=False, sheet_name=\"Pathway Summary\")\n",
        "\n",
        "df_export.to_csv(csv_path, index=False)\n",
        "print(f\"CSV saved  → {csv_path}\")\n",
        "\n",
        "\n",
        "# ── STEP 6: Style with openpyxl ───────────────────────────────────────────────\n",
        "HEADER_FILL  = PatternFill(\"solid\", fgColor=\"1F4E79\")\n",
        "PATHWAY_FILL = PatternFill(\"solid\", fgColor=\"D6E4F0\")\n",
        "ALT_FILL     = PatternFill(\"solid\", fgColor=\"F5F9FF\")\n",
        "SIG_FILL     = PatternFill(\"solid\", fgColor=\"FFF2CC\")\n",
        "WHITE_FILL   = PatternFill(\"solid\", fgColor=\"FFFFFF\")\n",
        "UNNAMED_FILL = PatternFill(\"solid\", fgColor=\"FFE0E0\")   # soft red for unnamed reactions\n",
        "\n",
        "HEADER_FONT  = Font(name=\"Arial\", bold=True, color=\"FFFFFF\", size=10)\n",
        "BODY_FONT    = Font(name=\"Arial\", size=9)\n",
        "PATH_FONT    = Font(name=\"Arial\", bold=True, size=9, color=\"1F4E79\")\n",
        "UNNAMED_FONT = Font(name=\"Arial\", size=9, italic=True, color=\"990000\")\n",
        "\n",
        "THIN   = Side(style=\"thin\",   color=\"BFBFBF\")\n",
        "CENTER = Alignment(horizontal=\"center\", vertical=\"center\", wrap_text=True)\n",
        "LEFT   = Alignment(horizontal=\"left\",   vertical=\"center\", wrap_text=True)\n",
        "\n",
        "wb = load_workbook(xlsx_path)\n",
        "\n",
        "# ── Pathway Table sheet ───────────────────────────────────────────────────────\n",
        "ws = wb[\"Pathway Table\"]\n",
        "ws.freeze_panes = \"A2\"\n",
        "ws.row_dimensions[1].height = 36\n",
        "\n",
        "COL_W = {\"A\":38,\"B\":14,\"C\":38,\"D\":50,\"E\":50,\"F\":60,\"G\":55,\"H\":10,\n",
        "          \"I\":14,\"J\":14,\"K\":16,\"L\":22,\"M\":22,\"N\":12}\n",
        "for col, w in COL_W.items():\n",
        "    ws.column_dimensions[col].width = w\n",
        "\n",
        "for cell in ws[1]:\n",
        "    cell.fill = HEADER_FILL; cell.font = HEADER_FONT; cell.alignment = CENTER\n",
        "\n",
        "# Column index of key fields (1-based)\n",
        "NAME_COL    = 4    # \"Reaction Name\"\n",
        "SIG_COL     = 14   # \"Significant (*)\" — 14 data cols → index 13 (0-based) = col 14 (1-based)\n",
        "NUMERIC_COLS = {8, 9, 10, 11}  # Gene Count, two fluxes, abs shift\n",
        "\n",
        "prev_pw  = None\n",
        "row_fill = WHITE_FILL\n",
        "\n",
        "for r_idx, excel_row in enumerate(ws.iter_rows(min_row=2), start=2):\n",
        "    pw_val      = excel_row[0].value                      # col A\n",
        "    name_val    = str(excel_row[NAME_COL - 1].value or \"\") # col D\n",
        "    sig_val     = excel_row[SIG_COL - 1].value            # col N\n",
        "    is_unnamed  = name_val.endswith(\"(unnamed)\")\n",
        "\n",
        "    if pw_val != prev_pw:\n",
        "        row_fill = PATHWAY_FILL if row_fill != PATHWAY_FILL else ALT_FILL\n",
        "        prev_pw = pw_val\n",
        "\n",
        "    for c_idx, cell in enumerate(excel_row, start=1):\n",
        "        if is_unnamed:\n",
        "            cell.fill = UNNAMED_FILL\n",
        "            cell.font = UNNAMED_FONT if c_idx == NAME_COL else BODY_FONT\n",
        "        elif sig_val == \"✓\":\n",
        "            cell.fill = SIG_FILL\n",
        "            cell.font = PATH_FONT if c_idx == 1 else BODY_FONT\n",
        "        else:\n",
        "            cell.fill = row_fill\n",
        "            cell.font = PATH_FONT if c_idx == 1 else BODY_FONT\n",
        "\n",
        "        cell.border    = Border(left=THIN, right=THIN, top=THIN, bottom=THIN)\n",
        "        cell.alignment = CENTER if c_idx in NUMERIC_COLS else LEFT\n",
        "\n",
        "    ws.row_dimensions[r_idx].height = 30\n",
        "\n",
        "# ── Pathway Summary sheet ─────────────────────────────────────────────────────\n",
        "ws2 = wb[\"Pathway Summary\"]\n",
        "ws2.freeze_panes = \"A2\"\n",
        "ws2.row_dimensions[1].height = 30\n",
        "\n",
        "for col, w in zip(\"ABCDEFG\", [45, 12, 14, 18, 16, 16, 18]):\n",
        "    ws2.column_dimensions[col].width = w\n",
        "\n",
        "for cell in ws2[1]:\n",
        "    cell.fill = HEADER_FILL; cell.font = HEADER_FONT; cell.alignment = CENTER\n",
        "\n",
        "for r_idx, row in enumerate(ws2.iter_rows(min_row=2), start=2):\n",
        "    fill = ALT_FILL if r_idx % 2 == 0 else WHITE_FILL\n",
        "    for cell in row:\n",
        "        cell.fill      = fill\n",
        "        cell.font      = BODY_FONT\n",
        "        cell.alignment = CENTER if cell.column > 1 else LEFT\n",
        "        cell.border    = Border(left=THIN, right=THIN, top=THIN, bottom=THIN)\n",
        "    ws2.row_dimensions[r_idx].height = 22\n",
        "\n",
        "wb.save(xlsx_path)\n",
        "print(f\"Excel saved → {xlsx_path}\")\n",
        "print(f\"\\n=== DONE ===\")\n",
        "print(f\"  'Pathway Table'   — {len(df_export)} reactions\")\n",
        "print(f\"  'Pathway Summary' — {df_export['Pathway'].nunique()} pathways\")"
      ]
