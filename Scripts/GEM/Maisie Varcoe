        "import pandas as pd\n",
        "from cobra.flux_analysis import flux_variability_analysis\n",
        "import time\n",
        "\n",
        "def cleanup(model):\n",
        "   # Identify all reactions to keep (No DMs, and only the first instance of any ID)\n",
        "    seen_ids = set()\n",
        "    to_keep = []\n",
        "    removed_duplicates = 0\n",
        "    removed_dms = 0\n",
        "\n",
        "    for rxn in model.reactions:\n",
        "        if rxn.id.startswith(\"DM_\"):\n",
        "            removed_dms += 1\n",
        "            continue\n",
        "        if rxn.id in seen_ids:\n",
        "            removed_duplicates += 1\n",
        "            continue\n",
        "        seen_ids.add(rxn.id)\n",
        "        to_keep.append(rxn)\n",
        "# Reconstruct the model's reaction list\n",
        "    new_model = cobra.Model(model.id)\n",
        "    new_model.add_reactions(to_keep)\n",
        "\n",
        "    # Explicitly preserve the objective\n",
        "    # If the model.objective was a reaction object, re-assign it by ID\n",
        "    if isinstance(model.objective, cobra.Reaction):\n",
        "        new_model.objective = model.objective.id\n",
        "    else:\n",
        "        new_model.objective = model.objective\n",
        "\n",
        "    print(f\"  Removed {removed_dms} DM reactions.\")\n",
        "    print(f\"  Removed {removed_duplicates} duplicate IDs.\")\n",
        "\n",
        "    # Check model\n",
        "    new_model.solver = 'glpk'\n",
        "    growth = new_model.slim_optimize()\n",
        "\n",
        "    if growth <= 0:\n",
        "        print(f\" WARNING: Model is non-functional after cleanup! (Growth: {growth:.4f})\")\n",
        "        print(\"Check if essential exchange reactions or the objective were removed.\")\n",
        "    else:\n",
        "        print(f\" Model healthy! Growth: {growth:.4f}\")\n",
        "\n",
        "    return new_model\n",
        "# Run cleanup on the CONTEXT models (_ctx)\n",
        "\n",
        "model_high_ctx = cleanup(model_high_ctx)\n",
