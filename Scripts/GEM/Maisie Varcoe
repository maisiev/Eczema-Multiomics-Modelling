      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Expression threshold (High SA): 0.0030\n",
            "Expression threshold (Low SA):  0.0047\n",
            "Reactions penalised — High SA: 5407 / 12931\n",
            "Reactions penalised — Low SA:  5455  / 12931\n",
            "Reactions with different weights (High vs Low): 5547\n"
          ]
        }
      ],
      "source": [
        "from cobra.core.gene import GPR\n",
        "from ast import And, Or\n",
        "\n",
        "def evaluate_gpr(gpr_node, expr_lookup):\n",
        "    \"\"\"\n",
        "    Recursively evaluate a COBRApy GPR expression tree.\n",
        "\n",
        "    AND nodes  → min (enzyme complex: all subunits needed)\n",
        "    OR  nodes  → max (isozymes: any isoform sufficient)\n",
        "    Leaf nodes → expression value from expr_lookup, or None if unmapped.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    gpr_node   : cobra GPR AST node\n",
        "    expr_lookup: dict  {gene_id: expression_value}\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    float or None\n",
        "    \"\"\"\n",
        "    # Import the AST node types COBRApy uses\n",
        "    from cobra.core.gene import Gene\n",
        "    import ast\n",
        "\n",
        "    if gpr_node is None:\n",
        "        return None\n",
        "\n",
        "    node_type = type(gpr_node).__name__\n",
        "\n",
        "    # Leaf: a single gene\n",
        "    if hasattr(gpr_node, 'id'):          # cobra Gene object\n",
        "        return expr_lookup.get(gpr_node.id, None)\n",
        "    if hasattr(gpr_node, 'name'):        # ast.Name node (gene symbol used as ID)\n",
        "        return expr_lookup.get(gpr_node.name, None)\n",
        "\n",
        "    # AND node: all subunits needed — bottleneck is the minimum\n",
        "    if hasattr(gpr_node, 'args') and isinstance(gpr_node, ast.BoolOp) and isinstance(gpr_node.op, ast.And):\n",
        "        child_vals = [evaluate_gpr(child, expr_lookup) for child in gpr_node.args]\n",
        "        child_vals = [v for v in child_vals if v is not None]\n",
        "        return min(child_vals) if child_vals else None\n",
        "\n",
        "    # OR node: any isoform sufficient — effective expression is the maximum\n",
        "    if hasattr(gpr_node, 'args') and isinstance(gpr_node, ast.BoolOp) and isinstance(gpr_node.op, ast.Or):\n",
        "        child_vals = [evaluate_gpr(child, expr_lookup) for child in gpr_node.args]\n",
        "        child_vals = [v for v in child_vals if v is not None]\n",
        "        return max(child_vals) if child_vals else None\n",
        "\n",
        "    # Fallback for any wrapper nodes\n",
        "    if hasattr(gpr_node, 'body'):\n",
        "        return evaluate_gpr(gpr_node.body, expr_lookup)\n",
        "\n",
        "    return None\n",
        "\n",
        "\n",
        "def build_reaction_weights(model, expr_series, threshold=None):\n",
        "    \"\"\"\n",
        "    Build continuous GIMME reaction weights using GPR-aware gene scoring.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    model       : cobra.Model\n",
        "    expr_series : pd.Series — index = Ensembl IDs, values = expression levels\n",
        "    threshold   : float or None\n",
        "        If None, uses the 10th percentile of non-zero expression values (data-driven).\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    dict {reaction_id: weight}\n",
        "        weight = max(0, threshold - gpr_expression)\n",
        "        0.0  → reaction supported by expression (no GIMME penalty)\n",
        "        >0.0 → penalised proportionally to expression deficit\n",
        "    float\n",
        "        The threshold used.\n",
        "\n",
        "    Notes\n",
        "    -----\n",
        "    GPR logic (Becker & Palsson 2008; Frontera et al. 2022 Frontiers Oncology):\n",
        "      AND-linked genes (enzyme subunits) → min expression (bottleneck)\n",
        "      OR-linked genes  (isozymes)        → max expression (most active isoform)\n",
        "    \"\"\"\n",
        "    import ast\n",
        "\n",
        "    nonzero_expr = expr_series[expr_series > 0]\n",
        "    if threshold is None:\n",
        "        threshold = float(np.percentile(nonzero_expr, 10)) if len(nonzero_expr) > 0 else 0.1\n",
        "\n",
        "    expr_lookup = expr_series.to_dict()\n",
        "    weights = {}\n",
        "\n",
        "    for rxn in model.reactions:\n",
        "        # No GPR → transport / exchange / spontaneous reaction: no penalty\n",
        "        if not rxn.gene_reaction_rule or rxn.gene_reaction_rule.strip() == '':\n",
        "            weights[rxn.id] = 0.0\n",
        "            continue\n",
        "\n",
        "        # Parse and evaluate GPR tree\n",
        "        try:\n",
        "            tree = ast.parse(rxn.gene_reaction_rule, mode='eval')\n",
        "            rxn_expr = evaluate_gpr(tree, expr_lookup)\n",
        "        except Exception:\n",
        "            rxn_expr = None\n",
        "\n",
        "        if rxn_expr is None:\n",
        "            # All genes in the GPR are unmapped → treat as fully absent (max penalty)\n",
        "            weights[rxn.id] = float(threshold)  # normalised max penalty = threshold\n",
        "        else:\n",
        "            weights[rxn.id] = max(0.0, threshold - float(rxn_expr))\n",
        "\n",
        "    return weights, threshold\n",
        "\n",
        "\n",
        "# Build GPR-aware weights for KER1 High and Low SA groups\n",
        "weights_high_KER1, thresh_high = build_reaction_weights(model, expr_high_KER1)\n",
        "weights_low_KER1,  thresh_low  = build_reaction_weights(model, expr_low_KER1)\n",
        "\n",
        "print(f\"Expression threshold (High SA): {thresh_high:.4f}\")\n",
        "print(f\"Expression threshold (Low SA):  {thresh_low:.4f}\")\n",
        "\n",
        "n_pen_high = sum(1 for w in weights_high_KER1.values() if w > 0)\n",
        "n_pen_low  = sum(1 for w in weights_low_KER1.values()  if w > 0)\n",
        "print(f\"Reactions penalised — High SA: {n_pen_high} / {len(weights_high_KER1)}\")\n",
        "print(f\"Reactions penalised — Low SA:  {n_pen_low}  / {len(weights_low_KER1)}\")\n",
        "\n",
        "common_rxns = set(weights_high_KER1) & set(weights_low_KER1)\n",
        "n_diff = sum(1 for r in common_rxns if abs(weights_high_KER1[r] - weights_low_KER1[r]) > 1e-6)\n",
        "print(f\"Reactions with different weights (High vs Low): {n_diff}\")"
      ]
